# QueueStorm Investigator — environment configuration template.
#
# Copy this file to `.env` and fill in the values:
#   cp .env.example .env
#
# LLM_PROVIDER:
#   - "stub"  : zero-config, deterministic regex/keyword extractor (default).
#   - "gemini": call Google Gemini via the `google-genai` SDK. Requires a
#               non-empty GEMINI_API_KEY.
#
# When LLM_PROVIDER=gemini but the key is missing or invalid, the service
# logs a warning and silently falls back to the stub extractor — the API
# will never return a 500 because of a missing key.
#
LLM_PROVIDER=stub

# Google Gemini API key (https://aistudio.google.com/apikey).
# Leave empty if LLM_PROVIDER=stub.
GEMINI_API_KEY=

# Gemini model to use. `gemini-1.5-flash` is fast and cheap; switch to
# `gemini-1.5-pro` if you need stronger reasoning for the demo.
GEMINI_MODEL=gemini-1.5-flash
